---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string | URL;
}

const { title, description, image = '/og-image.png', canonicalURL = new URL(Astro.url.pathname, Astro.site) } = Astro.props;

// All tutorials for the search index (flat list for auto-suggest)
const tutorialLinks = [
  { label: 'HTML Tutorial', href: '/tutorial/html-introduction', cat: 'HTML' },
  { label: 'CSS Tutorial', href: '/tutorial/css-introduction', cat: 'CSS' },
  { label: 'JavaScript Tutorial', href: '/tutorial/js-introduction', cat: 'JavaScript' },
  { label: 'SEO Tutorial', href: '/tutorial/seo-overview', cat: 'SEO' },
  { label: 'Python Tutorial', href: '/tutorial/python-guide', cat: 'Python' },
  { label: 'SQL Tutorial', href: '/tutorial/sql-guide', cat: 'SQL' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | CodesCompiler</title>
    <meta name="title" content={`${title} | CodesCompiler`} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | CodesCompiler`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | CodesCompiler`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

    {Astro.url.pathname.includes('/tutorial/python-') && (
      <>
        <link rel="stylesheet" href="https://pyscript.net/latest/pyscript.css" />
        <script defer src="https://pyscript.net/latest/pyscript.js"></script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased" style="font-family: 'Source Sans 3', sans-serif;">

    <!-- ============================================================ -->
    <!-- TOP WHITE NAV BAR                                            -->
    <!-- ============================================================ -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-screen-2xl mx-auto px-3 sm:px-5">
        <div class="flex items-center h-14 gap-3">

          <!-- Hamburger (mobile sidebar toggle) -->
          <button id="sidebar-toggle" class="flex-shrink-0 p-2 rounded hover:bg-gray-100 transition-colors md:hidden" aria-label="Toggle sidebar">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>

          <!-- Logo -->
          <a href="/" class="flex-shrink-0 flex items-center gap-1.5 no-underline">
            <span class="font-bold text-lg text-gray-900 tracking-tight whitespace-nowrap">
              <span class="text-[#04AA6D]">Codes</span>Compiler
            </span>
          </a>

          <!-- Center Search Bar -->
          <div class="flex-1 min-w-0 flex justify-center px-2 sm:px-6 max-w-2xl mx-auto relative" id="search-wrapper">
            <div class="w-full relative min-w-0">
              <input
                id="main-search"
                type="text"
                placeholder="Search tutorials, e.g. HTML"
                autocomplete="off"
                class="w-full pl-4 pr-12 py-2 border-2 border-gray-200 focus:border-[#04AA6D] rounded-md text-sm outline-none transition-colors bg-gray-50 focus:bg-white"
              />
              <button class="absolute right-0 top-0 h-full px-4 bg-[#04AA6D] hover:bg-[#038a58] rounded-r-md transition-colors flex items-center justify-center" aria-label="Search">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
              <!-- Autocomplete Dropdown -->
              <div id="search-dropdown" class="hidden absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-md shadow-xl z-50 overflow-hidden max-h-80 overflow-y-auto">
                <!-- Results injected by JS -->
              </div>
            </div>
          </div>

          <!-- Nav links (desktop only) -->
          <nav class="hidden lg:flex items-center gap-1 flex-shrink-0">
            <a href="/blog" class="text-sm font-medium text-gray-600 hover:text-[#04AA6D] px-3 py-2 rounded hover:bg-gray-50 transition-colors whitespace-nowrap">Posts</a>
            <a href="/about" class="text-sm font-medium text-gray-600 hover:text-[#04AA6D] px-3 py-2 rounded hover:bg-gray-50 transition-colors whitespace-nowrap">About</a>
            <a href="/contact" class="text-sm font-medium text-gray-600 hover:text-[#04AA6D] px-3 py-2 rounded hover:bg-gray-50 transition-colors whitespace-nowrap">Contact</a>
            <a href="/tutorial/html-introduction" class="ml-2 text-sm font-semibold text-white bg-[#04AA6D] hover:bg-[#038a58] px-4 py-2 rounded transition-colors whitespace-nowrap">Get Started</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- ============================================================ -->
    <!-- DARK LANGUAGE NAV STRIP (W3Schools-style)                    -->
    <!-- ============================================================ -->
    <div class="bg-[#282A35] border-b border-gray-700 sticky top-14 z-40 overflow-x-auto scrollbar-hide">
      <div class="max-w-screen-2xl mx-auto flex items-center min-w-max px-3 sm:px-5 h-10">
        {[
          { label: 'HTML', href: '/tutorial/html-introduction', color: '#E34F26' },
          { label: 'CSS', href: '/tutorial/css-introduction', color: '#264DE4' },
          { label: 'JavaScript', href: '/tutorial/js-introduction', color: '#F7DF1E' },
          { label: 'SEO', href: '/tutorial/seo-overview', color: '#04AA6D' },
          { label: 'Python', href: '/tutorial/python-guide', color: '#3776AB' },
          { label: 'SQL', href: '/tutorial/sql-guide', color: '#336791' },
          { label: 'Posts', href: '/blog', color: '#04AA6D' },
          { label: 'Privacy', href: '/privacy-policy', color: '#9CA3AF' },
          { label: 'About', href: '/about', color: '#9CA3AF' },
          { label: 'Contact', href: '/contact', color: '#9CA3AF' },
        ].map(item => (
          <a
            href={item.href}
            class="flex-shrink-0 text-xs font-semibold text-gray-300 hover:text-white hover:bg-white/10 px-4 py-2 transition-colors rounded whitespace-nowrap"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <!-- ============================================================ -->
    <!-- MAIN CONTENT + SIDEBAR WRAPPER                               -->
    <!-- ============================================================ -->
    <main class="flex-grow w-full flex flex-col" id="main-content">
      <slot />
    </main>

    <!-- ============================================================ -->
    <!-- FOOTER                                                        -->
    <!-- ============================================================ -->
    <footer class="bg-[#282A35] text-gray-400">
      <div class="max-w-screen-2xl mx-auto py-10 px-5">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <a href="/" class="text-lg font-bold text-white"><span class="text-[#04AA6D]">Codes</span>Compiler</a>
            <p class="text-sm mt-1 text-gray-500">Free web development tutorials for everyone.</p>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2">
            <a href="/about" class="text-sm hover:text-white transition-colors">About</a>
            <a href="/contact" class="text-sm hover:text-white transition-colors">Contact</a>
            <a href="/privacy-policy" class="text-sm hover:text-white transition-colors">Privacy Policy</a>
            <a href="/terms-of-service" class="text-sm hover:text-white transition-colors">Terms of Service</a>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-6 text-sm text-center text-gray-600">
          &copy; {new Date().getFullYear()} CodesCompiler.com — All rights reserved.
        </div>
      </div>
    </footer>

    <!-- ============================================================ -->
    <!-- SEARCH AUTOCOMPLETE JS                                        -->
    <!-- ============================================================ -->
    <script is:inline define:vars={{ tutorialLinks }}>
      const searchInput = document.getElementById('main-search');
      const dropdown = document.getElementById('search-dropdown');

      const allItems = tutorialLinks;

      function renderDropdown(query) {
        if (!query || query.length < 1) {
          dropdown.classList.add('hidden');
          return;
        }
        const q = query.toLowerCase();
        const matches = allItems.filter(
          item => item.label.toLowerCase().includes(q) || item.cat.toLowerCase().includes(q)
        );
        if (matches.length === 0) {
          dropdown.innerHTML = `<div class="px-4 py-3 text-sm text-gray-400 italic">No results found</div>`;
          dropdown.classList.remove('hidden');
          return;
        }
        dropdown.innerHTML = matches.map(item => `
          <a href="${item.href}" class="flex items-center gap-4 px-4 py-2.5 hover:bg-gray-50 border-b border-gray-100 last:border-none group">
            <span class="text-xs font-bold text-[#04AA6D] uppercase w-16 flex-shrink-0">${item.cat}</span>
            <span class="text-sm text-gray-800 group-hover:text-[#04AA6D]">${item.label}</span>
          </a>
        `).join('');
        dropdown.classList.remove('hidden');
      }

      searchInput?.addEventListener('input', (e) => renderDropdown(e.target.value));
      searchInput?.addEventListener('focus', (e) => renderDropdown(e.target.value));

      document.addEventListener('click', (e) => {
        if (!document.getElementById('search-wrapper')?.contains(e.target)) {
          dropdown?.classList.add('hidden');
        }
      });
    </script>

    <style is:global>
      /* Hide scrollbar on language nav strip */
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

      /* ============================================================ */
      /* GLOBAL TYPOGRAPHY FOR MDX (Tutorials & Posts)                */
      /* ============================================================ */
      .prose, .post-content {
        color: #374151;
        line-height: 1.75;
        font-size: 1.05rem;
      }
      
      .prose h1, .post-content h1 {
        font-size: 2.25rem;
        font-weight: 800;
        margin-top: 1.5em;
        margin-bottom: 0.8em;
        line-height: 1.2;
        color: #111827;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 0.3em;
      }

      .prose h2, .post-content h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-top: 2em;
        margin-bottom: 1em;
        color: #1f2937;
        border-left: 4px solid #04AA6D;
        padding-left: 12px;
        line-height: 1.3;
      }

      .prose h3, .post-content h3 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-top: 1.6em;
        margin-bottom: 0.6em;
        color: #374151;
        line-height: 1.4;
      }

      .prose h4, .post-content h4 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        color: #4b5563;
      }

      .prose p, .post-content p {
        margin-top: 1em;
        margin-bottom: 1.25em;
      }

      .prose a, .post-content a {
        color: #04AA6D;
        text-decoration: underline;
        text-underline-offset: 3px;
        font-weight: 500;
        transition: color 0.15s ease;
      }
      .prose a:hover, .post-content a:hover {
        color: #038a58;
      }

      .prose ul, .post-content ul {
        list-style-type: disc;
        padding-left: 1.5em;
        margin-top: 1em;
        margin-bottom: 1.25em;
      }

      .prose ol, .post-content ol {
        list-style-type: decimal;
        padding-left: 1.5em;
        margin-top: 1em;
        margin-bottom: 1.25em;
      }

      .prose li, .post-content li {
        margin-bottom: 0.5em;
      }

      .prose li > ul, .prose li > ol,
      .post-content li > ul, .post-content li > ol {
        margin-top: 0.5em;
        margin-bottom: 0;
      }

      .prose blockquote, .post-content blockquote {
        border-left: 4px solid #04AA6D;
        background: #f0fdf4;
        padding: 1rem 1.2rem;
        margin: 1.5em 0;
        font-style: italic;
        color: #4b5563;
        border-radius: 0 8px 8px 0;
      }

      /* Inline code vs Block code */
      .prose code:not(pre code), .post-content code:not(pre code) {
        background-color: #f3f4f6;
        color: #c7254e;
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.85em;
        font-family: 'Fira Code', monospace;
        word-break: break-word;
      }

      .prose pre, .post-content pre {
        background-color: #282A35;
        color: #f8f8f2;
        padding: 1.25em;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5em 0;
        font-family: 'Fira Code', monospace;
        font-size: 0.9em;
        line-height: 1.6;
        border: 1px solid rgba(0,0,0,0.1);
      }

      .prose pre code, .post-content pre code {
        background-color: transparent;
        color: inherit;
        padding: 0;
        border-radius: 0;
        font-size: 1em;
      }

      .prose img, .post-content img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 2em auto;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        display: block;
      }

      .prose table, .post-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5em 0;
        font-size: 0.95em;
      }

      .prose th, .post-content th {
        background-color: #f9fafb;
        font-weight: 700;
        text-align: left;
        padding: 0.75em 1em;
        border: 1px solid #e5e7eb;
        color: #111827;
      }

      .prose td, .post-content td {
        padding: 0.75em 1em;
        border: 1px solid #e5e7eb;
        color: #374151;
      }

      .prose tr:nth-child(even) td, .post-content tr:nth-child(even) td {
        background-color: #f9fafb;
      }

      .prose hr, .post-content hr {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 2.5em 0;
      }
      
      .prose strong, .post-content strong {
        font-weight: 700;
        color: #111827;
      }
    </style>
  </body>
</html>
